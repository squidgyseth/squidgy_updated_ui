    {
      "parameters": {
        "jsCode": "// Filter to Squidgy workflows updated today\nconst input = $input.first().json;\nconst workflows = Array.isArray(input.data) ? input.data : (Array.isArray(input) ? input : []);\n\n// --- SQUIDGY FILTER ---\nconst PREFIXES = [\n  'SA ', 'SA|', 'SA_', 'SA-',\n  'SW ', 'SW|', 'SW_',\n  'CRA',\n  'FK ', 'FK|', 'FK_', 'FK-',\n  'CR ', 'CR|', 'CR_',\n  'FA ', 'FA|',\n  'ALG',\n  'Brandy', 'Punk Branding', 'DONT ACTIVATE',\n  'Templated.io', 'April',\n];\nconst KEYWORDS = ['squidgy', 'brandy', 'social media mcp'];\n\nfunction isSquidgy(wf) {\n  const tags = (wf.tags || []).map(t => t.name || '');\n  if (tags.includes('Squidgy')) return true;\n  const name = wf.name || '';\n  for (const p of PREFIXES) {\n    if (name.startsWith(p)) return true;\n  }\n  const lower = name.toLowerCase();\n  for (const kw of KEYWORDS) {\n    if (lower.includes(kw)) return true;\n  }\n  return false;\n}\n\n// --- DATE FILTER ---\nconst now = new Date();\nconst today = `${now.getUTCFullYear()}-${String(now.getUTCMonth() + 1).padStart(2, '0')}-${String(now.getUTCDate()).padStart(2, '0')}`;\n\nconst results = workflows\n  .filter(wf => {\n    if (!isSquidgy(wf)) return false;\n    const updatedAt = wf.updatedAt || wf.updated_at;\n    if (!updatedAt) return false;\n    const d = new Date(updatedAt);\n    const updatedDate = `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}`;\n    return updatedDate === today;\n  })\n  .map(wf => ({ json: { id: wf.id, name: wf.name } }));\n\nreturn results;"
      },
