              "value": "openai/text-embedding-3-small"
            },
            {
              "name": "input",
              "value": "={{ $('When Called').item.json.new_content }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
