    {
      "parameters": {
        "jsCode": "// 1. Get the data passed down from previous node\nconst inputData = $input.first().json;\nconst steps = Array.isArray(inputData.intermediateSteps)\n  ? inputData.intermediateSteps\n  : [];\n\nconst returnItems = [];\n\n// 2. Loop through all steps\nsteps.forEach((step) => {\n  \n  const action = step.action || {};\n  \n  // Support multiple possible tool name properties\n  const toolName =\n    action.tool ||\n    action.toolName ||\n    action.name ||\n    action.id ||\n    null;\n\n  if (toolName) {\n    returnItems.push({\n      json: {\n        // --- Tool Data ---\n        tool_name: toolName,\n        tool_args: action.toolInput || action.input || null,\n        tool_output: step.observation || null,\n\n        // --- Context ---\n        user_id: inputData.user_id,\n        session_id: inputData.session_id,\n        request_id: inputData.request_id\n      }\n    });\n  }\n});\n\n// 3. Return one item per tool call\nreturn returnItems;\n"
      },
