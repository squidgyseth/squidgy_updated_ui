# Environment Configuration for Squidgy Frontend
# Copy this file to .env and fill in your actual values
# Only contains variables actually used in the frontend codebase

# =============================================================================
# BACKEND API CONFIGURATION (REQUIRED)
# =============================================================================
VITE_BACKEND_URL=http://localhost:8000

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# =============================================================================
# FRONTEND URL FOR AUTH REDIRECTS (REQUIRED)
# =============================================================================
VITE_FRONTEND_URL=http://localhost:5173

# =============================================================================
# NEON DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Neon Postgres REST API endpoint and credentials
# Used by backend to query user_vector_knowledge_base table
NEON_API_URL=https://ep-divine-cake-ab0mlfc9.apirest.eu-west-2.aws.neon.tech/neondb/rest/v1
NEON_API_KEY=your-neon-api-key-here

# =============================================================================
# N8N INTEGRATION (OPTIONAL)
# =============================================================================
VITE_N8N_WEBHOOK_URL=https://your-n8n-webhook-url

# =============================================================================
# GOOGLE CALENDAR INTEGRATION (OPTIONAL)
# =============================================================================
# Get these from Google Cloud Console OAuth2 credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.googleusercontent.com

# =============================================================================
# POSTHOG ANALYTICS (OPTIONAL - For Admin Analytics Dashboard)
# =============================================================================
# Get the embed URL from PostHog: Dashboard → Share → Enable public sharing → Copy embed code
# Extract the src URL from the iframe code (e.g., https://eu.posthog.com/embedded/xxxxx)
VITE_POSTHOG_EMBED_URL=https://eu.posthog.com/embedded/Es39G07zRneh4HEP_DCOwpUx9rvMfw
# =============================================================================
# APPLICATION SETTINGS (OPTIONAL)
# =============================================================================
VITE_APP_ENV=development
