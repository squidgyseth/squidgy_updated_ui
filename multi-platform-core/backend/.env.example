# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this to .env and fill in the values
# =============================================================================

# Default platform for local development
DEFAULT_PLATFORM_ID=squidgy

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# N8N Configuration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_API_KEY=your-n8n-api-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# MCP Server URL (for agent workflows)
MCP_SERVER_URL=https://your-mcp-server.com

# -----------------------------------------------------------------------------
# SQUIDGY
# -----------------------------------------------------------------------------
SQUIDGY_SUPABASE_URL=https://your-squidgy-project.supabase.co
SQUIDGY_SUPABASE_ANON_KEY=your-squidgy-anon-key
SQUIDGY_SUPABASE_SERVICE_KEY=your-squidgy-service-key

# -----------------------------------------------------------------------------
# YEAA
# -----------------------------------------------------------------------------
YEAA_SUPABASE_URL=https://your-yeaa-project.supabase.co
YEAA_SUPABASE_ANON_KEY=your-yeaa-anon-key
YEAA_SUPABASE_SERVICE_KEY=your-yeaa-service-key

# -----------------------------------------------------------------------------
# FANATIQ
# -----------------------------------------------------------------------------
FANATIQ_SUPABASE_URL=https://your-fanatiq-project.supabase.co
FANATIQ_SUPABASE_ANON_KEY=your-fanatiq-anon-key
FANATIQ_SUPABASE_SERVICE_KEY=your-fanatiq-service-key

# -----------------------------------------------------------------------------
# TRADES
# -----------------------------------------------------------------------------
TRADES_SUPABASE_URL=https://your-trades-project.supabase.co
TRADES_SUPABASE_ANON_KEY=your-trades-anon-key
TRADES_SUPABASE_SERVICE_KEY=your-trades-service-key

# -----------------------------------------------------------------------------
# FINANCE
# -----------------------------------------------------------------------------
FINANCE_SUPABASE_URL=https://your-finance-project.supabase.co
FINANCE_SUPABASE_ANON_KEY=your-finance-anon-key
FINANCE_SUPABASE_SERVICE_KEY=your-finance-service-key

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
