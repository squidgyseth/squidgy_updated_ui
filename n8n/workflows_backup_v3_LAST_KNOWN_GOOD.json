        "jsCode": "// Format workflow as named JSON and prepare for file conversion\nconst wf = $input.first().json;\n\nconst workflowName = wf.name || `workflow_${wf.id || Date.now()}`;\nconst sanitized = workflowName.replace(/[^a-zA-Z0-9_\\s-]/g, '').replace(/\\s+/g, '_').toLowerCase();\nconst fileName = `squidgy_${sanitized}.json`;\n\nreturn [{\n  json: {\n    fileName,\n    filePath: `From_N8N_Scheduler/${fileName}`,\n    workflow_json: wf\n  }\n}];"
      },
