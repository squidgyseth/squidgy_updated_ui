    {
      "parameters": {
        "jsCode": "const text = $input.first().json.body.user_mssg;\nconst body = $input.first().json.body;  \nconst userId = body.user_id;\n// Extract URL from message (uploaded file)\nconst urlMatch = text.match(/https?:\\/\\/[^\\s]+/);\nconst url = urlMatch ? urlMatch[0] : null;\n// Extract Supabase base URL from the uploaded file URL\nlet supabaseUrl = '';\nif (url) {\n  const baseMatch = url.match(/^(https:\\/\\/[^\\/]+\\.supabase\\.co)/);\n  supabaseUrl = baseMatch ? baseMatch[1] : '';\n}\n// Extract file extension from URL or filename\nlet format = null;\nif (url) {\n  const cleanUrl = url.split('?')[0];\n  format = cleanUrl.split('.').pop();\n}\n// Generate download links for all 12 KB files\nconst kbFiles = [\n  '01-company-overview.md',\n  '02-icp-target-audience.md',\n  '03-branding-identity.md',\n  '04-messaging-positioning.md',\n  '05-product-services.md',\n  '06-sales-process.md',\n  '07-marketing-channels.md',\n  '08-development-technical.md',\n  '09-operations-workflows.md',\n  '10-contacts-stakeholders.md',\n  '11-customer-success.md',\n  '12-competitive-landscape.md'\n];\n// Build download URLs for existing KB files\n// Path: knowledge-base/{user_id}/{filename}\nconst kbDownloadLinks = kbFiles.map(filename => ({\n  filename: filename,\n  download_url: `${supabaseUrl}/storage/v1/object/public/knowledge-base/${userId}/${filename}`\n}));\nreturn [\n  {\n    url,\n    format,\n    body,\n    user_id: userId,\n    supabase_url: supabaseUrl,\n    kb_files: kbDownloadLinks\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        48
      ],
      "id": "bb845b6d-5179-414b-8da9-f721c2450c75",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Get AI response - it's already just a message string\nconst aiOutput = $input.first().json;\nconst aiResponse = aiOutput.output || aiOutput.text || aiOutput;\n\n// Clean the response (remove any accidental JSON formatting if present)\nlet userMessage;\ntry {\n  // Check if AI accidentally returned JSON\n  const parsed = JSON.parse(aiResponse);\n  userMessage = parsed.message || aiResponse;\n} catch (e) {\n  // It's already a plain string, use it directly\n  userMessage = aiResponse;\n}\n\n// Convert HTML anchor tags to markdown links\nuserMessage = userMessage.replace(/<a\\s+[^>]*href=[\"']([^\"']+)[\"'][^>]*>([^<]+)<\\/a>/gi, '[$2]($1)');\n\n// Clean leftover attributes\nuserMessage = userMessage.replace(/target=[\"'][^\"']*[\"']\\s*/gi, '');\nuserMessage = userMessage.replace(/rel=[\"'][^\"']*[\"']\\s*/gi, '');\nuserMessage = userMessage.replace(/style=[\"'][^\"']*[\"']\\s*/gi, '');\n\n// ✅ RETURN (unchanged structure + intermediateSteps added)\nreturn {\n  json: {\n    user_id: $('Main Workflow').first().json.body.user_id,\n    session_id: $('Main Workflow').first().json.body.session_id,\n    agent_name: $('Main Workflow').first().json.body.agent_name,\n    timestamp_of_call_made: new Date().toISOString(),\n    request_id: $('Main Workflow').first().json.body.request_id,\n    agent_response: userMessage.trim(),\n\n    // 🔥 ADD THIS (for tool logger)\n    intermediateSteps: aiOutput.intermediateSteps || [],\n    // 🔥 Execution ID for admin debugging\n    execution_id: $execution.id,\n    workflow_id: $workflow.id\n  }\n};\n"
      },
