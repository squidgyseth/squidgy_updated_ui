# =============================================================================
# Frontend Environment Variables
# =============================================================================
# Copy this to .env.local and fill in the values
# =============================================================================

# Default platform for local development
# Options: squidgy, yeaa, fanatiq, trades, finance
NEXT_PUBLIC_PLATFORM_ID=squidgy

# Backend API URL
HEROKU_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# SQUIDGY
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SQUIDGY_SUPABASE_URL=https://your-squidgy-project.supabase.co
NEXT_PUBLIC_SQUIDGY_SUPABASE_ANON_KEY=your-squidgy-anon-key

# -----------------------------------------------------------------------------
# YEAA
# -----------------------------------------------------------------------------
NEXT_PUBLIC_YEAA_SUPABASE_URL=https://your-yeaa-project.supabase.co
NEXT_PUBLIC_YEAA_SUPABASE_ANON_KEY=your-yeaa-anon-key

# -----------------------------------------------------------------------------
# FANATIQ
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FANATIQ_SUPABASE_URL=https://your-fanatiq-project.supabase.co
NEXT_PUBLIC_FANATIQ_SUPABASE_ANON_KEY=your-fanatiq-anon-key

# -----------------------------------------------------------------------------
# TRADES
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TRADES_SUPABASE_URL=https://your-trades-project.supabase.co
NEXT_PUBLIC_TRADES_SUPABASE_ANON_KEY=your-trades-anon-key

# -----------------------------------------------------------------------------
# FINANCE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FINANCE_SUPABASE_URL=https://your-finance-project.supabase.co
NEXT_PUBLIC_FINANCE_SUPABASE_ANON_KEY=your-finance-anon-key
